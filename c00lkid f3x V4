---------------- PAGE NAVIGATION SYSTEM ----------------
local currentPage = 1
local maxPages = 4

local function updatePageVisibility()
    Page1Frame.Visible = (currentPage == 1)
    Page2Frame.Visible = (currentPage == 2)
    Page3Frame.Visible = (currentPage == 3)
    Page4Frame.Visible = (currentPage == 4)
    FooterLabel.Text = "Page " .. tostring(currentPage) .. " | Made by Qwertyyuiksj_6"
end

PrevPageBtn.MouseButton1Click:Connect(function()
    currentPage = currentPage - 1
    if currentPage < 1 then currentPage = maxPages end
    updatePageVisibility()
end)

NextPageBtn.MouseButton1Click:Connect(function()
    currentPage = currentPage + 1
    if currentPage > maxPages then currentPage = 1 end
    updatePageVisibility()
end)

FooterLabel.MouseButton1Click:Connect(function()
    currentPage = currentPage + 1
    if currentPage > maxPages then currentPage = 1 end
    updatePageVisibility()
end)


---------------- RECONSTRUCTED FUNCTION LOGIC ----------------
local function getF3XTool()
    local character = Player.Character
    local backpack = Player.Backpack
    
    if character then
        for _, child in ipairs(character:GetChildren()) do
            if child:IsA("Tool") and (string.find(child.Name, "F3X") or string.find(child.Name, "Building")) then
                return child
            end
        end
    end
    
    if backpack then
        for _, child in ipairs(backpack:GetChildren()) do
            if child:IsA("Tool") and (string.find(child.Name, "F3X") or string.find(child.Name, "Building")) then
                return child
            end
        end
    end
    return nil
end

local function fireChatMessages(messagesList)
    local textChannel = game:GetService("TextChatService"):FindFirstChild("TextChannels") and game:GetService("TextChatService").TextChannels:FindFirstChild("RBXGeneral")
    local replicatedStorageRemote = game:GetService("ReplicatedStorage"):FindFirstChild("DefaultChatSystemChatEvents") and game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
    
    task.spawn(function()
        for _, msg in ipairs(messagesList) do
            if textChannel then
                textChannel:SendAsync(msg)
            elseif replicatedStorageRemote then
                replicatedStorageRemote:FireServer(msg, "All")
            end
            task.wait(0.4)
        end
    end)
end

-- Decal Changer Logic
ActionButton.MouseButton1Click:Connect(function()
    local decalId = TextBox.Text
    if decalId == "" or decalId == "Put Decal ID Here" then
        ActionButton.Text = "Input ID First!"
        task.wait(2)
        ActionButton.Text = "Change All\nParts\n(F3X)"
        return
    end
    
    local f3x = getF3XTool()
    if not f3x then
        ActionButton.Text = "No F3X Found!\nHold Tool."
        task.wait(2)
        ActionButton.Text = "Change All\nParts\n(F3X)"
        return
    end
    
    local syncAPI = f3x:FindFirstChild("SyncAPI") or f3x:FindFirstChild("Server") or f3x:FindFirstChild("Sync")
    if not syncAPI then return end
    local serverEndpoint = syncAPI:FindFirstChild("ServerEndpoint") or syncAPI
    
    local formattedId = tostring(decalId)
    if not string.find(formattedId, "http") and not string.find(formattedId, "rbxassetid") then
        formattedId = "rbxassetid://" .. formattedId
    end

    local allParts = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("BasePart") then table.insert(allParts, obj) end
    end

    if #allParts > 0 then
        local BATCH_SIZE = 40
        local faces = {Enum.NormalId.Top, Enum.NormalId.Bottom, Enum.NormalId.Front, Enum.NormalId.Back, Enum.NormalId.Left, Enum.NormalId.Right}
        ActionButton.Text = "Running..."
        task.spawn(function()
            for _, face in ipairs(faces) do
                for i = 1, #allParts, BATCH_SIZE do
                    local creationTargets, syncTargets = {}, {}
                    for j = i, math.min(i + BATCH_SIZE - 1, #allParts) do
                        local part = allParts[j]
                        if part and part.Parent then
                            table.insert(creationTargets, {["Part"] = part, ["Face"] = face, ["TextureType"] = "Decal"})
                            table.insert(syncTargets, {["Part"] = part, ["Face"] = face, ["TextureType"] = "Decal", ["Texture"] = formattedId})
                        end
                    end
                    pcall(function()
                        serverEndpoint:InvokeServer("CreateTextures", creationTargets)
                        serverEndpoint:InvokeServer("SyncTexture", syncTargets)
                    end)
                    task.wait()
                end
            end
            ActionButton.Text = "Success!"
            task.wait(2)
            ActionButton.Text = "Change All\nParts\n(F3X)"
        end)
    end
end)

-- Fire Logic
FirePartsButton.MouseButton1Click:Connect(function()
    FirePartsButton.Text = "Igniting..."
    task.spawn(function()
        local batchCounter = 0
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj:FindFirstChildOfClass("Fire") then
                local fire = Instance.new("Fire")
                fire.Size, fire.Heat = 5, 5
                fire.Parent = obj
                batchCounter = batchCounter + 1
                if batchCounter >= 30 then
                    batchCounter = 0
                    task.wait()
                end
            end
        end
        FirePartsButton.Text = "Done!"
        task.wait(2)
        FirePartsButton.Text = "Fire All\nParts /\nPlayers"
    end)
end)

-- Page 2 Staggered FE Server Unanchor Logic
local unanchoring = false
UnanchorButton.MouseButton1Click:Connect(function()
    if unanchoring then return end
    
    local f3x = getF3XTool()
    if not f3x then
        UnanchorButton.Text = "Hold F3X Tool First!"
        task.wait(2)
        UnanchorButton.Text = "Unanchor All (FE Server)"
        return
    end
    
    local syncAPI = f3x:FindFirstChild("SyncAPI") or f3x:FindFirstChild("Server") or f3x:FindFirstChild("Sync")
    if not syncAPI then return end
    local serverEndpoint = syncAPI:FindFirstChild("ServerEndpoint") or syncAPI
    
    unanchoring = true
    UnanchorButton.Text = "Dropping Server..."
    
    task.spawn(function()
        local batch = {}
        local BATCH_SIZE = 30
        
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Anchored and not obj:IsDescendantOf(Player.Character) then
                table.insert(batch, obj)
                
                if #batch >= BATCH_SIZE then
                    pcall(function()
                        serverEndpoint:InvokeServer("SyncAnchor", batch, false)
                    end)
                    table.clear(batch)
                    task.wait()
                end
            end
        end
        
        if #batch > 0 then
            pcall(function()
                serverEndpoint:InvokeServer("SyncAnchor", batch, false)
            end)
        end
        
        UnanchorButton.Text = "Finished!"
        task.wait(2)
        UnanchorButton.Text = "Unanchor All (FE Server)"
        unanchoring = false
    end)
end)

