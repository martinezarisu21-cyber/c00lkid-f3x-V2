local deleting = false
DeleteButton.MouseButton1Click:Connect(function()
    if deleting then return end
    
    local f3x = getF3XTool()
    if not f3x then
        DeleteButton.Text = "Hold F3X Tool First!"
        task.wait(2)
        DeleteButton.Text = "Delete All (FE Server Fix)"
        return
    end
    
    local syncAPI = f3x:FindFirstChild("SyncAPI") or f3x:FindFirstChild("Server") or f3x:FindFirstChild("Sync")
    if not syncAPI then return end
    local serverEndpoint = syncAPI:FindFirstChild("ServerEndpoint") or syncAPI
    
    deleting = true
    DeleteButton.Text = "Deleting Workspace..."
    
    task.spawn(function()
        local fullTargetList = {}
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj:IsDescendantOf(Player.Character) and obj.Name ~= "Terrain" then
                table.insert(fullTargetList, obj)
            end
        end
        
        local batch = {}
        local BATCH_SIZE = 30
        
        for _, part in ipairs(fullTargetList) do
            if part and part.Parent then
                table.insert(batch, part)
                
                if #batch >= BATCH_SIZE then
                    pcall(function()
                        serverEndpoint:InvokeServer("Remove", batch)
                    end)
                    table.clear(batch)
                    task.wait()
                end
            end
        end
        
        if #batch > 0 then
            pcall(function()
                serverEndpoint:InvokeServer("Remove", batch)
            end)
        end
        
        DeleteButton.Text = "Finished Cleanup!"
        task.wait(2)
        DeleteButton.Text = "Delete All (FE Server Fix)"
        deleting = false
    end)
end)
