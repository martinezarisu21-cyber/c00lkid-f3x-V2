--// Fast Smooth Lock Aim
--// Stronger sensitivity
--// Works with NO teams
--// Mobile GUI + Wall Check

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

----------------------------------------------------
-- SETTINGS
----------------------------------------------------
local SmoothnessValue = 50 -- [SCALE: 1 - 150] Higher = Faster/Snappier, Lower = Smoother
local FOVRadius = 320

-- Convert the 1-150 scale to a 0-1 alpha value for Lerp
local Smoothness = math.clamp(SmoothnessValue / 150, 0.01, 1)

----------------------------------------------------
-- GUI
----------------------------------------------------
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "FastLockAim"
ScreenGui.Parent = game.CoreGui

local Main = Instance.new("Frame")
Main.Parent = ScreenGui
Main.Size = UDim2.new(0,170,0,60)
Main.Position = UDim2.new(0.5,-85,0.75,0)
Main.BackgroundColor3 = Color3.fromRGB(20,20,20)
