--------------------------------------------------------------------------------
-- ORBIT & RAINBOW LOGIC
--------------------------------------------------------------------------------
local isOrbiting = false
local orbitConnection = nil
local originalCFrame = nil

local ORBIT_RADIUS = 2.5
local ORBIT_SPEED = 45
local CAMERA_OFFSET = Vector3.new(0, 4, 10)

-- Search player by Name or DisplayName
local function getSpecificPlayer(targetName)
    if targetName == "" then return nil end
    local searchLower = targetName:lower()

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer then
            local username = player.Name:lower()
            local displayName = player.DisplayName:lower()

            if username:sub(1, #searchLower) == searchLower or displayName:sub(1, #searchLower) == searchLower then
                if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    return player.Character
                end
            end
        end
    end
    return nil
end

-- Search nearest player
local function getNearestPlayer()
    local nearestTarget = nil
    local shortestDistance = math.huge

    if not humanoidRootPart then return nil end

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= localPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local targetHRP = player.Character.HumanoidRootPart
            local distance = (targetHRP.Position - humanoidRootPart.Position).Magnitude
            
            if distance < shortestDistance then
                shortestDistance = distance
                nearestTarget = player.Character
            end
        end
    end

    return nearestTarget
end

-- Toggle behavior
toggleButton.MouseButton1Click:Connect(function()
    isOrbiting = not isOrbiting

    if isOrbiting then
        toggleButton.Text = "Orbit: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 100)

        if humanoidRootPart then
            originalCFrame = humanoidRootPart.CFrame
        end

        -- Attach rainbow highlight to local character
        if character then
            highlight.Parent = character
            highlight.Enabled = true
        end

        camera.CameraType = Enum.CameraType.Scriptable

        local currentAngle = 0
        local hue = 0

        -- Main Orbit and Visual Loop
        orbitConnection = RunService.RenderStepped:Connect(function(deltaTime)
            if not isOrbiting or not humanoidRootPart then return end

            -- Smooth rainbow color cycle
            hue = (hue + (0.5 * deltaTime)) % 1
            local rainbowColor = Color3.fromHSV(hue, 0.8, 1)

            highlight.FillColor = rainbowColor
            highlight.OutlineColor = rainbowColor
            uiStroke.Color = rainbowColor

            -- Orbit calculation
            local inputTarget = targetTextBox.Text
            local targetCharacter = nil

            if inputTarget ~= "" then
                targetCharacter = getSpecificPlayer(inputTarget)
            else
                targetCharacter = getNearestPlayer()
            end

            if targetCharacter and targetCharacter:FindFirstChild("HumanoidRootPart") then
                local targetHRP = targetCharacter.HumanoidRootPart
                
                currentAngle = currentAngle + (ORBIT_SPEED * deltaTime)
                local offset = CFrame.Angles(0, currentAngle, 0) * CFrame.new(0, 0, ORBIT_RADIUS)
                humanoidRootPart.CFrame = targetHRP.CFrame * offset

                -- Locked stable camera
                local targetPos = targetHRP.Position
                local cameraPos = targetPos + CAMERA_OFFSET
                camera.CFrame = CFrame.new(cameraPos, targetPos)
            end
        end)
    else
        toggleButton.Text = "Orbit: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 45)

        -- Disable rainbow highlight & restore UI stroke
        highlight.Enabled = false
        highlight.Parent = nil
        uiStroke.Color = Color3.fromRGB(255, 255, 255)

        camera.CameraType = Enum.CameraType.Custom

        if orbitConnection then
            orbitConnection:Disconnect()
            orbitConnection = nil
        end

        if humanoidRootPart and originalCFrame then
            humanoidRootPart.CFrame = originalCFrame
        end
    end
end)
