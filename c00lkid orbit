local function createParticle()
    local particle = Instance.new("Frame")
    particle.Size = UDim2.new(0, math.random(3, 6), 0, math.random(3, 6))
    particle.Position = UDim2.new(math.random(), 0, 1, 0)
    particle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    particle.BackgroundTransparency = 0.5
    particle.BorderSizePixel = 0
    particle.ZIndex = 1
    particle.Parent = mainFrame

    local pCorner = Instance.new("UICorner")
    pCorner.CornerRadius = UDim.new(1, 0)
    pCorner.Parent = particle

    local duration = math.random(3, 6)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local goal = {
        Position = UDim2.new(particle.Position.X.Scale, 0, -0.1, 0),
        BackgroundTransparency = 1
    }

    local tween = TweenService:Create(particle, tweenInfo, goal)
    tween:Play()
    tween.Completed:Connect(function()
        particle:Destroy()
    end)
end

-- Spawn floating particles periodically
task.spawn(function()
    while true do
        createParticle()
        task.wait(0.4)
    end
end)

