-- Copy Utility
local function copyToClipboard(text)
	if setclipboard then
		setclipboard(text)
	else
		print("Copied: " .. text)
	end
end

local pages = {}
local tabButtons = {}

local function switchTab(tabName)
	for name, page in pairs(pages) do
		if name == tabName then
			page.Visible = true
			TweenService:Create(tabButtons[name], TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 162, 255), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
		else
			page.Visible = false
			TweenService:Create(tabButtons[name], TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 30, 40), TextColor3 = Color3.fromRGB(150, 150, 150)}):Play()
		end
	end
end

-- Generate dynamic layout elements
for tabName, textList in pairs(ReportData) do
	-- Creating Sidebar Tab Buttons
	local TabButton = Instance.new("TextButton")
	TabButton.Size = UDim2.new(0.9, 0, 0, 35)
	TabButton.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
	TabButton.Text = tabName
	TabButton.TextColor3 = Color3.fromRGB(150, 150, 150)
	TabButton.TextSize = 13
	TabButton.Font = Enum.Font.GothamSemibold
	TabButton.BorderSizePixel = 0
	TabButton.Parent = TabButtonContainer
	
	local TabBtnCorner = Instance.new("UICorner")
	TabBtnCorner.CornerRadius = UDim.new(0, 6)
	TabBtnCorner.Parent = TabButton
	
	tabButtons[tabName] = TabButton
	
	-- Content Scrolling Frame
	local ScrollFrame = Instance.new("ScrollingFrame")
	ScrollFrame.Size = UDim2.new(1, 0, 1, 0)
	ScrollFrame.BackgroundTransparency = 1
	ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, #textList * 50)
	ScrollFrame.ScrollBarThickness = 4
	ScrollFrame.ScrollBarImageColor3 = Color3.fromRGB(0, 162, 255)
	ScrollFrame.Visible = false
	ScrollFrame.Parent = PagesContainer
	
	pages[tabName] = ScrollFrame
	
	local UIListLayout = Instance.new("UIListLayout")
	UIListLayout.Padding = UDim.new(0, 8)
	UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
	UIListLayout.Parent = ScrollFrame
	
	-- Populating Text Selection Options
	for i, reportText in ipairs(textList) do
		local TextButton = Instance.new("TextButton")
		TextButton.Size = UDim2.new(1, -8, 0, 42)
		TextButton.BackgroundColor3 = Color3.fromRGB(26, 26, 36)
		TextButton.Text = "   " .. reportText
		TextButton.TextColor3 = Color3.fromRGB(200, 200, 200)
		TextButton.TextSize = 11
		TextButton.TextXAlignment = Enum.TextXAlignment.Left
		TextButton.Font = Enum.Font.Gotham
		TextButton.TextWrapped = true
		TextButton.BorderSizePixel = 0
		TextButton.Parent = ScrollFrame
		
		local ButtonCorner = Instance.new("UICorner")
		ButtonCorner.CornerRadius = UDim.new(0, 6)
		ButtonCorner.Parent = TextButton
		
		-- Button Hover Animations
		TextButton.MouseEnter:Connect(function()
			TweenService:Create(TextButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(36, 36, 48), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
		end)
		TextButton.MouseLeave:Connect(function()
			TweenService:Create(TextButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(26, 26, 36), TextColor3 = Color3.fromRGB(200, 200, 200)}):Play()
		end)
		
		-- Click Action Sequence
		TextButton.MouseButton1Click:Connect(function()
			copyToClipboard(reportText)
			
			local originalColor = TextButton.BackgroundColor3
			TextButton.BackgroundColor3 = Color3.fromRGB(46, 125, 50) -- Success Green
			TextButton.Text = "   COPIED PHRASE TO CLIPBOARD!"
			
			task.wait(0.5)
			TextButton.BackgroundColor3 = originalColor
			TextButton.Text = "   " .. reportText
		end)
	end
	
	TabButton.MouseButton1Click:Connect(function()
		switchTab(tabName)
	end)
end

-- Load Default View
switchTab("Bullying")
